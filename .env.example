# CreatorOS Environment Variables
# Copy this file to .env and fill in your API keys

# Claude API (required for script generation)
CLAUDE_API_KEY=sk-ant-...

# OpenAI API (for embeddings - text-embedding-3-small)
OPENAI_API_KEY=sk-...

# Notion API (optional - for exporting to Notion)
NOTION_API_KEY=secret_...

# YouTube Data API (optional - for trend analysis)
YOUTUBE_API_KEY=...

# N8N Configuration
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme

# RAG Service Configuration
RAG_SERVICE_PORT=8080
CHROMA_HOST=chromadb
CHROMA_PORT=8000
OLLAMA_HOST=ollama
OLLAMA_PORT=11434

# Embedding Configuration
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
